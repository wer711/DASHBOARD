# متغيرات البيئة — لوحة تحليلات صدى العقار
# انسخ هذا الملف إلى .env واملأ القيم

# === قاعدة البيانات ===
# محلياً (SQLite):
DATABASE_URL="file:./db/custom.db"

# للنشر على Vercel: استبدل بـ Vercel Postgres connection string
# مثال: DATABASE_URL="postgres://user:pass@host:5432/db?sslmode=require"

# === خدمة WebSocket اللحظية (اختياري) ===
# إن لم تُضبط، ستعمل اللوحة بـ polling كل 10 ثوانٍ (شبه لحظي)
# للنشر: اضبطها على رابط خدمة الـ WebSocket المنشورة (مثل Render)
# LIVE_SERVICE_URL="https://your-live-service.onrender.com"

# === الواجهة الأمامية ===
# نفس رابط خدمة الـ WebSocket لكن يُستخدم في المتصفح
# NEXT_PUBLIC_LIVE_SERVICE_URL="https://your-live-service.onrender.com"

# === مصادر التتبع المسموح بها (CORS) ===
# مفصولة بفواصل — مصادر إضافية للسماح بإرسال أحداث التتبع
# ALLOWED_TRACKING_ORIGINS="https://sada-elaqar.vercel.app,https://example.com"
